import os
import speech_recognition as sr
import pyttsx3
import webbrowser
from google_auth_oauthlib.flow import InstalledAppFlow
from googleapiclient.discovery import build
from google import genai

# --- 1. Configuration & API Setup ---
SCOPES = ['https://www.googleapis.com/auth/youtube.force-ssl']
GEMINI_API_KEY = "YOUR_GEMINI_API_KEY"

# Initialize Gemini Client
client = genai.Client(api_key=GEMINI_API_KEY)
# Create a persistent chat session for "Memory"
chat_session = client.chats.create(model="gemini-2.0-flash")

# --- 2. YouTube Authentication ---
def get_youtube_service():
    flow = InstalledAppFlow.from_client_secrets_file('client_secrets.json', SCOPES)
    credentials = flow.run_local_server(port=0)
    return build('youtube', 'v3', credentials=credentials)

# --- 3. Voice Engine ---
engine = pyttsx3.init()
def speak(text):
    print(f"Assistant: {text}")
    engine.say(text)
    engine.runAndWait()

def listen():
    r = sr.Recognizer()
    with sr.Microphone() as source:
        print("Listening...")
        r.pause_threshold = 1
        audio = r.listen(source)
        try:
            query = r.recognize_google(audio)
            print(f"User: {query}")
            return query.lower()
        except:
            return ""

# --- 4. YouTube Logic ---
def play_on_youtube(service, song_name):
    request = service.search().list(
        q=song_name, part='snippet', type='video', maxResults=1
    )
    response = request.execute()
    if response['items']:
        video_id = response['items'][0]['id']['videoId']
        url = f"https://www.youtube.com/watch?v={video_id}"
        speak(f"Playing {song_name} on YouTube.")
        webbrowser.open(url)
    else:
        speak("I couldn't find that video.")

# --- 5. Main Execution Loop ---
if __name__ == "__main__":
    youtube_service = get_youtube_service()
    speak("System online. How can I help you today?")

    while True:
        command = listen()
        if not command:
            continue

        # Feature 1: YouTube Command
        if 'play' in command:
            song = command.replace('play', '').strip()
            play_on_youtube(youtube_service, song)

        # Exit Command
        elif 'stop' in command or 'exit' in command:
            speak("Goodbye!")
            break

        # Feature 2: Gen AI / General Questions (with Memory)
        else:
            try:
                # chat_session handles the history automatically
                response = chat_session.send_message(command)
                speak(response.text)
            except Exception as e:
                speak("I'm having trouble connecting to my brain right now.")
                print(e)
